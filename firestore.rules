rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email == "wildandamang@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidRsvp(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.attendance is string && (data.attendance == "hadir" || data.attendance == "tidak_hadir") &&
             data.guestsCount is int && data.guestsCount >= 0 && data.guestsCount <= 10 &&
             data.phoneNumber is string && data.phoneNumber.size() >= 5 && data.phoneNumber.size() <= 20 &&
             data.createdAt is timestamp;
    }

    function isValidMessage(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 500 &&
             data.createdAt is timestamp;
    }

    // RSVPs collection
    match /rsvps/{rsvpId} {
      // Allow public creation of RSVPs (under strict validation)
      allow create: if isValidId(rsvpId) && 
                       isValidRsvp(request.resource.data) &&
                       request.resource.data.checkedIn == false &&
                       request.resource.data.createdAt == request.time;
      
      // Allow public get if the guest wants to see their own RSVP/QR Code
      allow get: if true;

      // Allow only admin to list RSVPs
      allow list: if isAdmin();

      // Allow admin to update RSVPs (e.g. check-in status or check-in time)
      allow update: if isAdmin() && 
                       isValidRsvp(request.resource.data) &&
                       (
                         // Admin Action: Check in or update check-in time
                         (request.resource.data.checkedIn == true) ||
                         // Admin Action: General edit
                         (request.resource.data.checkedIn == resource.data.checkedIn)
                       );

      // Allow only admin to delete RSVPs
      allow delete: if isAdmin();
    }

    // Messages collection
    match /messages/{messageId} {
      // Allow anyone to create a message (wishes)
      allow create: if isValidId(messageId) && 
                       isValidMessage(request.resource.data) &&
                       request.resource.data.createdAt == request.time;

      // Allow anyone to read messages (to display on wishes list)
      allow read, list: if true;

      // Only admin can delete messages (to moderate bad content)
      allow delete: if isAdmin();

      // Nobody can update messages (immutable wishes)
      allow update: if false;
    }
  }
}
