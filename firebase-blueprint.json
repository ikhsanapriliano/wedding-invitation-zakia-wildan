{
  "entities": {
    "rsvp": {
      "title": "RSVP",
      "description": "RSVP details for wedding guests",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the guest" },
        "attendance": { "type": "string", "enum": ["hadir", "tidak_hadir"], "description": "Attendance status" },
        "guestsCount": { "type": "integer", "description": "Number of guests" },
        "phoneNumber": { "type": "string", "description": "Phone number for WhatsApp" },
        "createdAt": { "type": "string", "format": "date-time", "description": "RSVP date" },
        "checkedIn": { "type": "boolean", "description": "Whether guest checked in via QR" },
        "checkInTime": { "type": "string", "format": "date-time", "description": "Check-in timestamp" }
      },
      "required": ["name", "attendance", "guestsCount", "phoneNumber", "createdAt"]
    },
    "message": {
      "title": "Message",
      "description": "Greeting and wishes from guests",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the guest" },
        "text": { "type": "string", "description": "Greeting wishes text" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Message creation timestamp" }
      },
      "required": ["name", "text", "createdAt"]
    }
  },
  "firestore": {
    "rsvps/{rsvpId}": {
      "schema": "rsvp",
      "description": "Collection of wedding RSVPs"
    },
    "messages/{messageId}": {
      "schema": "message",
      "description": "Collection of greetings/wishes from guests"
    }
  }
}
